//Valid Parentheses
//first attempt I could finished it by myself!! ...with flaw
class Solution {
    public boolean isValid(String s) {
        Stack<Character> stack = new Stack<>();
        stack.push(s.charAt(0));
        for(int i = 1; i < s.length(); i ++){
            if(s.charAt(i) == ')' && stack.peek() == '('){
                stack.pop();
            }
            else if(s.charAt(i) == ']' && stack.peek() == '['){
                stack.pop();
            }
            else if(s.charAt(i) == '}' && stack.peek() == '{'){
                stack.pop();
            }
            else if((s.charAt(i) == '(' || s.charAt(i) == '{' || s.charAt(i) == '['))
            {
                stack.push(s.charAt(i));
            }
            else{
                return false;
            }
            if(stack.size() == 0)
                return true;//Not needed
        }
        return false;
    }
}
//first attempt but with chat GPT and solution from Leet Code
class Solution {
    public boolean isValid(String s) {
        Stack<Character> stack = new Stack<>();

        for(int i = 0; i < s.length(); i ++){
            char c = s.charAt(i);//重複は短く

            if(c == '(' || c ==  '[' || c ==  '{')//開始と終わりを分ける
                stack.push(c);
            else{
                if(stack.isEmpty())//］、｝、）から始まったとき
                return false;

                char top = stack.pop();//重複
                if((c == ')' && top != '(') || (c == ']' && top != '[') || (c == '}' && top != '{'))
                {//内容がそろってるか確認
                    return false;
                }
            }
        }
        return stack.isEmpty();//空ならtrue何か入っていればfalse
    }
}
