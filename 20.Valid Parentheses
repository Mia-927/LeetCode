        Stack<Character> stack = new Stack<>();
        if(s.length() == 0 || s == null)
            return true;
        if(s.length() % 2 == 1)
            return false;

        for(int i = 0; i < s.length(); i ++){
            char currentChar = s.charAt(i);
            if(currentChar == '(' || currentChar == '{' || currentChar == '['){
                stack.push(currentChar);
            }
            else{//もしかしてswitchの方が早い？
                if(i == 0 || stack.isEmpty())
                    return false;
                if(currentChar == ')'){
                    if(stack.peek() != '(')
                      return false;
                    stack.pop();
                }
                else if(currentChar == ']'){
                    if(stack.peek() != '[')
                      return false;
                    stack.pop();
                }
                else if(currentChar == '}'){
                    if(stack.peek() != '{')
                      return false;
                    stack.pop();
                }
            }
