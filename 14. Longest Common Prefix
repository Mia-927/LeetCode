//same attempt but with the solution from LeetCode
class Solution {
    public String longestCommonPrefix(String[] strs) {
        if(strs == null || strs.length == 0)//strsが空なら
        return "";
        String prefix = strs[0];//strsの1個目
        for(int i = 1; i < strs.length; i ++){
            while(strs[i].indexOf(prefix) != 0){//prefixが先頭一致してないなら//strsのi個目のprefixがどこから始まるか　＝＝　０じゃない
                prefix = prefix.substring(0, prefix.length() - 1);//1文字ずつprefixを削ってる（後ろの数字は含まれてない）
                if(prefix.isEmpty()) return "";
            }
        }
        return prefix;
    }
}
