//first attempt on solving 14. Longest Common Prefix
class Solution {
    public String longestCommonPrefix(String[] strs) {
        String aws = "";
        int min = strs[strs.length - 1].length();
        for(int i = 0; i < strs.length; i ++){
            if(min > strs[i].length()){//間違えてmax逆求めてた
                min = strs[i].length();
            }
        }
        for(int i = 0; i < min; i ++){
            //index bugにならないようにするの苦手
            char c = strs[0].charAt(i);
            for(int j = 0; j < strs.length; j ++){
                if(strs[j].charAt(i) != c){
                    return aws;
                }
                
            }
            aws += c;
        }
        return aws;
    }
}
