class Solution {
    //かぶりなし数字が何個あるか返すだけ
    public int removeDuplicates(int[] nums) {
        HashMap<Integer, Integer> map = new HashMap<>();
        map.put(nums[0], 1);
        int count = 0;
        for(int i = 1; i < nums.length; i++){
            if(map.containsKey(nums[i])){
                count ++;
            }
            else{
                map.put(nums[i], 1);
            }
        }
        return nums.length - count;
    }
}
