class Solution {
    //かぶりなし数字が何個あるか返すだけ
    public int removeDuplicates(int[] nums) {
        HashMap<Integer, Integer> map = new HashMap<>();
        map.put(nums[0], 1);
        int count = 0;
        for(int i = 1; i < nums.length; i++){
            if(map.containsKey(nums[i])){
                count ++;
            }
            else{
                map.put(nums[i], 1);
            }
        }
        return nums.length - count;
    }
}
//rewriten 書き直したけどバグの直し方分からん
class Solution {
    public int removeDuplicates(int[] nums) {
        //numsも書き換えること勘違いしてたからやり直し
        int len = nums.length;
        int count = 0;
        for(int i = 0; i < len - 1; i ++){
            if(nums[i] == nums[i + 1]){
                nums[i] = nums[len - i - 1];
                count ++;
            }
        }
        return count;
    }
}
//with AI絶対複数回やらないと！
class Solution {
    public int removeDuplicates(int[] nums) {
        //numsも書き換えること勘違いしてたからやり直し
        int k = 1;//1でも０でもＲｅｔｕｒｎ　＋１すればいい、なんで？
        for(int i = 1; i < nums.length; i ++){//後ろ比較型から前比較型に
            if(nums[i] != nums[i - 1]){//違う場合だけ通す
                nums[k] = nums[i];//もっと違う名前がよさそう、
                k ++;
            }
        }
        return k;
    }
}
