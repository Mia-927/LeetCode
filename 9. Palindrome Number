class Solution {
    public boolean isPalindrome(int x) {
        if(x < 0 || (x != 0 && x % 10 == 0))
        return false;
        String str = x.;//intをStringにするメソッド
        for(int i = 0; i < str.length() /2; i++){
            if(str.charAt(i) != str.charAt(str.length() - 1 - i){
                return false;
            }
        }
        return true;
    }
}
