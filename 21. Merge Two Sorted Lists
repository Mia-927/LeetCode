class Solution {//急に出されてもListNodeが何なのか分からんよ！！ ListNode == 自分の値と次のListNodeを持つPointer
    public ListNode mergeTwoLists(ListNode list1, ListNode list2) {
        ListNode lstN = new ListNode();
        if(list1 == null || list2 == null || (list1.length() == 0 && list2.length() == 0)){
            return lstN;
        }
        for(int i = 0; i < list1; i++){//非効率なのはわかるけど理解のために
            lstN.add(list1(i));
        }
        for(int i = 0; i < list2; i++){
            lstN.add(list2(i));
        }
        return lstN.sort();
    }
}
